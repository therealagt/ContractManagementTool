# Copy to terraform.tfvars and fill in values. Never commit terraform.tfvars.

project_id = "your-gcp-project-id"
region     = "europe-west3"
domain     = "contracts-dev.example.com"

# Restrict IAP users to your Google Workspace / Cloud Identity domain(s)
# allowed_email_domains = ["example.com"]

# Set true after creating IAP OAuth client in GCP Console
enable_iap = false
# iap_oauth_client_id     = ""
# iap_oauth_client_secret = ""

iap_access_groups = [
  # "grp-contract-uploader@example.com",
  # "grp-contract-reviewer@example.com",
  # "grp-contract-auditor@example.com",
  # "grp-contract-admin@example.com",
]

# App-level RBAC (email allowlists; admins receive all roles)
# auth_uploader_emails = ["uploader@example.com"]
# auth_reviewer_emails = ["reviewer@example.com"]
# auth_auditor_emails  = ["auditor@example.com"]
# auth_admin_emails    = ["admin@example.com"]

# After building API image:
# api_image = "europe-west3-docker.pkg.dev/your-project/contract-mgmt-dev/contract-api:latest"
