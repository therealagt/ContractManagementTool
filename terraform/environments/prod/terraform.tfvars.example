# Copy to terraform.tfvars and fill in values. Never commit terraform.tfvars.

project_id = "your-gcp-project-id"
region     = "europe-west3"
domain     = "contracts.example.com"

enable_bucket_lock          = true
enable_iap                  = true
enable_org_policies         = true
enable_binary_authorization = true
enable_cicd                 = true
db_tier                     = "db-g1-small"

allowed_email_domains = ["example.com"]

# VPN or office egress CIDR for Cloud Armor (required in prod)
cloud_armor_allowed_ips = [
  # "203.0.113.0/24",
]

# iap_oauth_client_id     = ""
# iap_oauth_client_secret = ""

iap_access_groups = [
  # "grp-contract-uploader@example.com",
  # "grp-contract-reviewer@example.com",
  # "grp-contract-auditor@example.com",
  # "grp-contract-admin@example.com",
]

auth_uploader_emails = [
  # "uploader@example.com",
]
auth_reviewer_emails = [
  # "reviewer@example.com",
]
auth_auditor_emails = [
  # "auditor@example.com",
]
auth_admin_emails = [
  # "admin@example.com",
]

alert_email_ops   = "grp-contract-ops@example.com"
alert_email_admin = "grp-contract-admin@example.com"
alert_email_audit = "grp-contract-auditor@example.com"

email_from = "contract-mgmt@example.com"
smtp_host  = "smtp.example.com"
smtp_port  = 587
smtp_user  = "contract-mgmt@example.com"
# smtp_password_secret_id = "smtp-password"

github_org  = "your-github-org"
github_repo = "ContractManagementTool"

# api_image = "europe-west3-docker.pkg.dev/your-project/contract-mgmt-prod/contract-api:latest"
# weekly_report_image = "europe-west3-docker.pkg.dev/your-project/contract-mgmt-prod/contract-weekly-report:latest"
